{
  "name": "noctune-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "assets:verify": "node scripts/verify-raster-assets.mjs",
    "build": "pnpm assets:verify && next build",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "check": "pnpm format:check && pnpm lint:md && pnpm test:assets && pnpm test:capture-safety && pnpm screenshots:verify && pnpm tsc && pnpm build",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "remark 'content/**/*.{md,mdx}' --frail --quiet",
    "lint:md:fix": "remark 'content/**/*.{md,mdx}' --output --quiet",
    "prepare": "husky",
    "release": "semantic-release",
    "screenshots:contact-sheet": "node scripts/make-screenshot-contact-sheets.mjs",
    "screenshots:install": "playwright install chromium",
    "screenshots:update": "node scripts/capture-screenshots.mjs",
    "screenshots:verify": "node scripts/verify-screenshots.mjs",
    "start": "next start",
    "test:assets": "node --test scripts/verify-raster-assets.test.mjs",
    "test:capture-safety": "node --test capture/support/capture-safety.test.mjs",
    "tsc": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "prettier --write"
    ],
    "*.{json,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@theguild/remark-mermaid": "0.3.0",
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.1",
    "nextra": "^4.2.17",
    "nextra-theme-docs": "^4.2.17",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "dotenv": "17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^2.5.22",
    "remark-cli": "12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint": "10.0.1",
    "remark-lint-no-dead-urls": "2.0.1",
    "remark-mdx": "3.1.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-preset-lint-markdown-style-guide": "6.0.1",
    "remark-preset-lint-recommended": "7.0.1",
    "semantic-release": "^25.0.3",
    "sharp": "0.34.5",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.33.0"
}
