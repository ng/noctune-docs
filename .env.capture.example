# Noctune documentation screenshot capture
#
# Copy this file to `.env.capture.local` for local use. The local file is
# gitignored and may contain secrets; this example file must never contain
# real credentials.

# Direct (unpooled) connection string for the empty, disposable Neon database
# used only to seed deterministic synthetic data for documentation screenshots.
# The capture runner will expose this to the spawned Noctune Core process as
# `DATABASE_URL`. Never point this at a development or production database.
CAPTURE_DATABASE_URL=""

# Required safety acknowledgement. The runner refuses to migrate or seed unless
# this exact value is present alongside the disposable capture database URL.
CAPTURE_DATABASE_GUARD="noctune-docs-capture-only"

# URL where Playwright will reach Noctune Core during capture. The capture
# runner starts the isolated local application on this port by default.
CAPTURE_BASE_URL="http://localhost:3100"

# Path from this repository to the Noctune Core checkout that will be launched
# and photographed.
CAPTURE_CORE_DIR="../noctune-core"

# Supabase is used only for authentication. Local capture will reuse the DEV
# Supabase settings already stored in Noctune Core's `.env.local`, so those
# credentials should not be duplicated here.

# Synthetic, non-admin identity reserved for documentation captures. The
# capture runner generates a new ephemeral password on every run and never
# writes that password to disk.
DOCS_CAPTURE_USER_EMAIL="docs-capture@test.noctune.local"

# Freeze browser and fixture time so screenshots do not drift from day to day.
DOCS_CAPTURE_NOW="2026-07-15T17:00:00.000Z"
